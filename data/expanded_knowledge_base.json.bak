    {
      "case_id": "engine_wear_oil_burning",
      "name": "Engine Oil Burning (Worn Rings/Valves)",
      "logic": "low_idle.hc > 500 and low_idle.co > 0.5 and low_idle.o2 < 1.0 and low_idle.co2 < 12.0",
